# ── Autenticação ──────────────────────────────────────────────────────────────
# Gere com: openssl rand -hex 32
JWT_SECRET=troque-por-uma-string-aleatoria-longa

# Admin criado automaticamente na primeira execução (se o banco estiver vazio)
ADMIN_EMAIL=admin@suaempresa.com
ADMIN_PASSWORD=senha-forte-aqui

# ── Servidor RustDesk ─────────────────────────────────────────────────────────
# IP ou hostname do servidor hbbs/hbbr
SERVER_IP=seu-servidor.com

# Chave pública: cat /caminho/data/id_ed25519.pub  (ou nos logs do hbbs)
SERVER_KEY=SUA_CHAVE_PUBLICA_AQUI

# URL pública desta API (usada no instalador .exe gerado automaticamente)
API_URL=http://seu-servidor.com:21114

# ── Banco de dados ────────────────────────────────────────────────────────────
# Preenchido automaticamente pelo docker-compose — edite só se usar banco externo
# DATABASE_URL=postgres://usuario:senha@host:5432/rustdesk_plus

# ── Opcional ──────────────────────────────────────────────────────────────────
# BIND_ADDR=0.0.0.0:21114

# No dashboard/.env.local:
# NEXT_PUBLIC_API_URL=http://seu-servidor.com:21114
