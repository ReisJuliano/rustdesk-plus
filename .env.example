# ── Segredos ──────────────────────────────────────────────────────────────────
# Gere com: openssl rand -hex 32
JWT_SECRET=troque-por-uma-string-aleatoria-longa
POSTGRES_PASSWORD=troque-por-senha-forte

# ── Servidor RustDesk ─────────────────────────────────────────────────────────
PUBLIC_HOST=ip-ou-dominio-do-servidor
PUBLIC_API_URL=http://ip-ou-dominio-do-servidor

# ── Gateway (HTTP ou HTTPS) ───────────────────────────────────────────────────
# HTTP  (usar IP, sem domínio): deixe como :80
# HTTPS (domínio público):      coloque o domínio, ex: painel.suaempresa.com
#   → O Caddy obtém o certificado Let's Encrypt automaticamente.
#   → Exige portas 80 e 443 abertas e DNS apontando para este servidor.
CADDY_ADDR=:80

# ── Portas publicadas pelo gateway ────────────────────────────────────────────
# Instalação direta: mantenha os padrões abaixo.
# Com Nginx/Apache no host:
#   WEB_BIND=127.0.0.1
#   WEB_PORT=8090
#   HTTPS_BIND=127.0.0.1
#   HTTPS_PORT=8443
WEB_BIND=0.0.0.0
WEB_PORT=80
HTTPS_BIND=0.0.0.0
HTTPS_PORT=443
